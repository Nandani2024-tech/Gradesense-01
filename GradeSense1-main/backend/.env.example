# --- MongoDB Settings ---
MONGO_URL=mongodb://mongodb:27017/gradesense
DB_NAME=gradesense

# --- Google OAuth Settings ---
# Create these at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_secret_here

# --- Authentication Settings ---
JWT_SECRET_KEY=generate_a_random_string_here

# --- Feature Flags ---
COLLEGE_V2_PIPELINE_ENABLED=true
MARK_VALIDATION_ENABLED=true
